+int _stricmp(
+   const char *string1,
+   const char *string2
+) {
+  std::size_t i = 0u;
+  while( true ) {
+    if( string1[ i ] == '\0' ) {
+      if( string2[ i ] == '\0' ) {
+        return 0;
+      }
+      else {
+        return 1;
+      }
+    }
+    else if( string2[ i ] == '\0' ) {
+      return -1;
+    }
+    if( string1[ i ] < string2[ i ] ) {
+      return -1;
+    }
+    if( string1[ i ] > string2[ i ] ) {
+      return 1;
+    }
+  }
+  return 0;
+}
+
+}
